{
  "compilerOptions": {
    "strict": true,
    "experimentalDecorators": true,
    "lib": ["dom", "es2020"],
    "module": "preserve",
    "target": "es2020",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "esModuleInterop": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src"]
}
